# General
POWERLIT_CROSSREF_MAILTO=your-email@example.com
POWERLIT_UNPAYWALL_EMAIL=
POWERLIT_LITERATURE_ROOT=literature
POWERLIT_REFERENCE_DIR=literature/reference
POWERLIT_MD_DIR=literature/md
POWERLIT_METADATA_DIR=literature/metadata
POWERLIT_OUTPUT_DIR=literature/metadata
POWERLIT_DOWNLOAD_LIST_DIR=literature/metadata/download_list
POWERLIT_RAG_OUTPUT_DIR=literature/json/rag
POWERLIT_CAS_JOURNAL_LIST_PATH=config/cas_journal_whitelist.xlsx
POWERLIT_CAS_MAX_QUARTILE=2
POWERLIT_DB_PATH=literature/metadata/papers.db
POWERLIT_INCOMING_PDF_DIR=incoming_pdf
POWERLIT_PARSED_OUTPUT_DIR=literature/json
POWERLIT_ANALYSIS_OUTPUT_DIR=literature/json
POWERLIT_INDEX_DIR=literature/index
POWERLIT_VECTOR_INDEX_DIR=literature/index/vector_index
