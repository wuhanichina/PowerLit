POWERLIT_INDEX_ROOT=literature/index/evidence
POWERLIT_REPORTS_DIR=literature/reports
POWERLIT_WEEKLY_REPORTS_DIR=literature/reports/weekly
POWERLIT_MONTHLY_REPORTS_DIR=literature/reports/monthly
POWERLIT_REQUEST_TIMEOUT=30
POWERLIT_PDF_TRANSCRIPTION_BACKEND=mineru
POWERLIT_DEBUG_OUTPUT_DIR=debug/output

# IEEE Xplore Metadata API
POWERLIT_IEEE_API_KEY=

# Elsevier / Scopus
POWERLIT_ELSEVIER_API_KEY=
POWERLIT_ELSEVIER_INSTTOKEN=
POWERLIT_SEMANTIC_SCHOLAR_API_KEY=
POWERLIT_OPENSCHOLAR_PES2O_URL=

# Optional service defaults
POWERLIT_API_HOST=127.0.0.1
POWERLIT_API_PORT=8000

# External AI
POWERLIT_DASHSCOPE_API_KEY=
POWERLIT_AI_PROVIDER=siliconflow
POWERLIT_AI_BASE_URL=https://api.siliconflow.cn/v1
POWERLIT_AI_API_KEY=
POWERLIT_AI_MODEL=Qwen/Qwen2.5-72B-Instruct
POWERLIT_AI_TEMPERATURE=0.1
POWERLIT_AI_TIMEOUT=60
POWERLIT_AI_NOTE_TIMEOUT=600
POWERLIT_AI_SOURCE_CHAR_LIMIT=16000
POWERLIT_AI_NOTE_SOURCE_CHAR_LIMIT=90000
POWERLIT_AI_FILE_PROCESSING_TIMEOUT=180
POWERLIT_AI_FILE_PROCESSING_POLL_INTERVAL=2
POWERLIT_AI_DELETE_UPLOADED_FILES_AFTER_NOTE=true
POWERLIT_AI_NOTE_TRANSCRIPTION_MODE=auto
POWERLIT_AI_LOCAL_PDF_TEXT_BACKEND=auto
POWERLIT_AI_LOCAL_PDF_TEXT_TIMEOUT=30
POWERLIT_AI_CURRENCY=CNY
POWERLIT_AI_INPUT_PRICE_PER_MTOKENS=
POWERLIT_AI_OUTPUT_PRICE_PER_MTOKENS=

